# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# OpenAI
OPENAI_API_KEY=sk-proj-...

# Plane
PLANE_API_KEY=plane_api_...
PLANE_WORKSPACE_SLUG=remotestar
PLANE_BASE_URL=https://plane.remotestar.io/api
PLANE_PROJECT_RECRUITER=4bb732bf-fb31-45c3-bbbd-1b0d71d30e61
PLANE_PROJECT_CANDIDATE=3d54afaf-b347-4730-aa9e-4ac43861503d

# MongoDB (audit log; reuse remotestar_candidate cluster)
MONGODB_URI=mongodb+srv://...
MONGODB_DATABASE=remotestar_candidate

# Bot config
PORT=9001
LOG_LEVEL=INFO

# Channels are configured by dropping markdown files into instructions/plane/
# or instructions/chatbot/. The bot ignores any channel without a file.

# Daily standup cron — DM each Plane member their pending tickets at this UTC hour.
# Set to a value 0..23 to enable, or -1 (default) to disable.
# 4 = 09:30 IST.
STANDUP_HOUR_UTC=-1
